# =============================================================================
#  CFAO Automotive — SAV / Réclamations — Configuration d'environnement
#  Copier ce fichier en `.env` et renseigner les vraies valeurs.
# =============================================================================

# --- Application ------------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
VITE_APP_URL=http://localhost:3000
COMPANY_NAME="CFAO Automotive"

# --- Sécurité ---------------------------------------------------------------
# Générer une chaîne aléatoire longue, ex: openssl rand -base64 48
SESSION_SECRET=change-me-with-a-long-random-string
# Store de session : 'pg' (PostgreSQL) ou 'memory' (dev). 'pg' forcé en production.
SESSION_STORE=memory

# --- Base de données PostgreSQL (Supabase) ----------------------------------
# Supabase > Project Settings > Database > Connection string (URI)
# Format : postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/cfao_sav?schema=public"
# URL "pooler" (pgbouncer) pour le runtime serverless (optionnel) :
# DIRECT_URL est utilisé par Prisma pour les migrations.
DIRECT_URL="postgresql://postgres:password@localhost:5432/cfao_sav?schema=public"

# --- Stockage des pièces jointes (Supabase Storage) -------------------------
# Supabase > Project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=complaint-attachments

# --- Emails (Brevo / SMTP) --------------------------------------------------
# Brevo > SMTP & API > SMTP
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=sav@cfao.com
# Si vide ou incomplet, les emails sont simulés dans les logs (mode dev).

# --- Escalade SLA (heures) — défauts, ajustables ----------------------------
SLA_CRITICAL_HOURS=4
SLA_HIGH_HOURS=24
SLA_MEDIUM_HOURS=72
SLA_LOW_HOURS=120
# Intervalle de passage du moteur d'escalade (minutes)
ESCALATION_CRON_MINUTES=15
# Active les jobs planifiés (escalade). Toujours actif en production.
ENABLE_JOBS=false

# --- IA (optionnel) ---------------------------------------------------------
# Classification / suggestion de catégorie & causes racines / résumé client
AI_ENABLED=false
GEMINI_API_KEY=
